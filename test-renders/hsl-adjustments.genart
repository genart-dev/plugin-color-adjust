  "id": "hsl-adjustments",
  "title": "HSL Adjustments",
  "created": "2026-03-06T00:00:00Z",
  "modified": "2026-03-06T00:00:00Z",
  "renderer": { "type": "canvas2d" },
  "canvas": { "width": 388, "height": 418 },
  "parameters": [],
  "colors": [],
  "state": { "seed": 1, "params": {}, "colorPalette": [] },
  "algorithm": "function sketch(ctx, state) {\n  var CW = 260, CH = 60, PAD = 4, LABEL_W = 120, ROWS = 6;\n  ctx.fillStyle = '#1a1a2e';\n  ctx.fillRect(0, 0, 388, 418);\n  for (var row = 0; row < ROWS; row++) {\n    var x = LABEL_W + PAD;\n    var y = 30 + row * (CH + PAD);\n    var grad = ctx.createLinearGradient(x, y, x + CW, y);\n    grad.addColorStop(0, '#ff0000');\n    grad.addColorStop(0.17, '#ffff00');\n    grad.addColorStop(0.33, '#00ff00');\n    grad.addColorStop(0.5, '#00ffff');\n    grad.addColorStop(0.67, '#0000ff');\n    grad.addColorStop(0.83, '#ff00ff');\n    grad.addColorStop(1, '#ff0000');\n    ctx.fillStyle = grad;\n    ctx.fillRect(x, y, CW, CH);\n  }\n  return {};\n}",
