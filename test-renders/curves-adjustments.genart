  "id": "curves-adjustments",
  "title": "Curves Adjustments",
  "created": "2026-03-06T00:00:00Z",
  "modified": "2026-03-06T00:00:00Z",
  "renderer": { "type": "canvas2d" },
  "canvas": { "width": 408, "height": 354 },
  "parameters": [],
  "colors": [],
  "state": { "seed": 1, "params": {}, "colorPalette": [] },
  "algorithm": "function sketch(ctx, state) {\n  var CW = 260, CH = 60, PAD = 4, LABEL_W = 140, ROWS = 5;\n  ctx.fillStyle = '#1a1a2e';\n  ctx.fillRect(0, 0, 408, 354);\n  for (var row = 0; row < ROWS; row++) {\n    var x = LABEL_W + PAD;\n    var y = 30 + row * (CH + PAD);\n    var grad = ctx.createLinearGradient(x, y + CH, x, y);\n    grad.addColorStop(0, '#3a2a1a');\n    grad.addColorStop(0.3, '#6b8e5a');\n    grad.addColorStop(0.5, '#7ab648');\n    grad.addColorStop(0.7, '#87ceeb');\n    grad.addColorStop(1, '#4a9fd8');\n    ctx.fillStyle = grad;\n    ctx.fillRect(x, y, CW, CH);\n    var grad2 = ctx.createLinearGradient(x, y, x + CW, y);\n    grad2.addColorStop(0, 'rgba(255,200,100,0.3)');\n    grad2.addColorStop(0.5, 'rgba(255,200,100,0)');\n    grad2.addColorStop(1, 'rgba(100,150,255,0.2)');\n    ctx.fillStyle = grad2;\n    ctx.fillRect(x, y, CW, CH);\n  }\n  return {};\n}",
